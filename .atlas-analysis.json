  "keyFeatures": [
    "Gamified dashboard with XP, levels, and daily streaks",
    "Challenge catalog with customizable templates and duration tracking",
    "Daily task management with CRUD and completion tracking",
    "Progress journal (notes) for active challenges",
    "JWT-based authentication with session management",
    "Dark and light theme support",
    "Responsive layout for mobile and desktop",
    "Zustand global state management",
    "Zod + React Hook Form validation"
  ],
  "publicApiSurface": [
    "authService.login(email, password)",
    "authService.signup(name, email, password)",
    "challengeService.listTemplates()",
    "challengeService.createTemplate({ title, description, duration_days })",
    "challengeService.deleteTemplate(id)",
    "challengeService.acceptChallenge(templateId)",
    "challengeService.getActiveChallenge()",
    "challengeService.listMyChallenges()",
    "challengeService.completeChallenge(id)",
    "challengeService.abandonChallenge(id)",
    "challengeService.updateNotes(id, notes)",
    "taskService.createTask(data: CreateTaskData)",
    "taskService.listMyTasks()",
    "taskService.updateTask(taskId, data: UpdateTaskData)",
    "taskService.deleteTask(taskId)",
    "taskService.completeTask(taskId, photoUrl?)",
    "userService.getProfile()",
    "userService.updateProfile(data: UpdateProfileData)"
  ]
}
